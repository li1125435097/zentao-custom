# 禅道 API 凭据配置
# 复制本文件为 .env 并填入真实值

# 禅道访问地址
ZENTAO_BASE_URL=https://mdsteam.medisyn.cc:1857

# 方式一：直接使用 API Token（可选）
# curl -sk -X POST -H "Content-Type: application/json" \
#   -d '{"account":"medisyn","password":"YOUR_PASSWORD"}' \
#   https://mdsteam.medisyn.cc:1857/api.php/v1/tokens
# ZENTAO_API_TOKEN=

# 方式二：使用管理员账号自动登录获取 Token（推荐）
ZENTAO_ADMIN_ACCOUNT=medisyn
ZENTAO_ADMIN_PASSWORD=YOUR_PASSWORD

# 默认部门（应用开发部 = 1）
ZENTAO_DEFAULT_DEPT_ID=1
ZENTAO_DEFAULT_DEPT_NAME=应用开发部

# 本地服务端口
PORT=3000
HOST=0.0.0.0

# 超级管理员 Token（可访问全部菜单，含权限管理）
MANAGER_TOKEN=

# API 调用日志（默认 backend/logs/api.log）
# API_LOG_DIR=backend/logs
# API_LOG_FILE=backend/logs/api.log
